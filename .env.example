# Copy this file to ".env" for local testing, OR add these as
# Environment Variables in Vercel (Project → Settings → Environment Variables).
# NEVER commit the real connection string — .env is gitignored.

# MongoDB Atlas connection string (Atlas → Connect → Drivers → Node.js)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Optional — database name (defaults to "fathersday")
MONGODB_DB=fathersday
